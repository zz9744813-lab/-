# Core app
DATABASE_URL=file:./data/compass.db

# Brain provider selection: disabled | hermes-bridge | openai-compatible
BRAIN_PROVIDER=disabled

# Hermes bridge mode (recommended for Hermes integration)
HERMES_BRIDGE_URL=http://127.0.0.1:8787
HERMES_BRIDGE_TOKEN=

# Direct OpenAI-compatible fallback mode
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Legacy variable kept for backward compatibility only (not preferred)
HERMES_API_URL=

# Shared token for Compass webhook / MCP auth
HERMES_TOKEN=
