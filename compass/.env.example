# Core app
DATABASE_URL=file:./data/compass.db

# Compass v4 Architecture: Hermes Agent
# Hermes handles all LLM API keys and model configurations.
# Point this to the gateway running on your Hermes environment.
HERMES_API_URL="http://127.0.0.1:8642"
HERMES_API_KEY="optional-hermes-token"
HERMES_MODEL="hermes-agent"

# Compass MCP auth token for Hermes -> Compass writes
COMPASS_MCP_TOKEN="optional-mcp-token-for-compass"

# Schedule email reminders
# A systemd timer or cron can call GET /api/reminders/schedule every minute.
# If REMINDER_CRON_TOKEN is empty, HERMES_TOKEN is used for Bearer auth.
REMINDER_CRON_TOKEN=
COMPASS_REMINDER_EMAIL=

# SMTP is preferred. If SMTP_HOST is empty, Compass tries /usr/sbin/sendmail.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_PASS_FILE=
SMTP_FROM=
SMTP_EHLO_DOMAIN=compass.local
SENDMAIL_PATH=/usr/sbin/sendmail
