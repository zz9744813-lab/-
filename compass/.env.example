# Core app
DATABASE_URL=file:./data/compass.db

# Brain provider: disabled | hermes-bridge
BRAIN_PROVIDER=hermes-bridge

# Hermes Bridge: external FastAPI service that talks to Hermes Agent
HERMES_BRIDGE_URL=http://127.0.0.1:8787
HERMES_BRIDGE_TOKEN=

# Compass MCP / webhook auth token for Hermes -> Compass writes
HERMES_TOKEN=

# Schedule email reminders
# A systemd timer or cron can call GET /api/reminders/schedule every minute.
# If REMINDER_CRON_TOKEN is empty, HERMES_TOKEN is used for Bearer auth.
REMINDER_CRON_TOKEN=
COMPASS_REMINDER_EMAIL=

# SMTP is preferred. If SMTP_HOST is empty, Compass tries /usr/sbin/sendmail.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_PASS_FILE=
SMTP_FROM=
SMTP_EHLO_DOMAIN=compass.local
SENDMAIL_PATH=/usr/sbin/sendmail
