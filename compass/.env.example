# Core app
DATABASE_URL=file:./data/compass.db

# Brain provider: disabled | hermes-bridge
BRAIN_PROVIDER=hermes-bridge

# Hermes Bridge — 真正的大脑入口
# 必须是外部 hermes-bridge 服务地址（FastAPI），Compass 通过它调用 Hermes Agent
HERMES_BRIDGE_URL=http://127.0.0.1:8787
HERMES_BRIDGE_TOKEN=

# Compass MCP / webhook 鉴权用（供 Hermes 反向调用 Compass 用）
HERMES_TOKEN=
